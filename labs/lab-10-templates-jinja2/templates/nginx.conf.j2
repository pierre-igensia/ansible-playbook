{# Template de configuration Nginx généré par Ansible #}
{# Généré le {{ ansible_date_time.date }} - NE PAS MODIFIER MANUELLEMENT #}

user www-data;
worker_processes {{ nginx_worker_processes | default('auto') }};
pid /run/nginx.pid;

events {
    worker_connections {{ nginx_worker_connections | default(768) }};
    multi_accept on;
}

http {
    ##
    # Paramètres de base
    ##
    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout {{ nginx_keepalive_timeout | default(65) }};
    types_hash_max_size 2048;
    server_tokens off;

    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    ##
    # Journalisation
    ##
    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log;

    ##
    # Compression Gzip
    ##
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;

    ##
    # Hôtes virtuels
    ##
{% for vhost in nginx_vhosts %}
    server {
        listen {{ vhost.port | default(80) }};
        server_name {{ vhost.server_name }};
        root {{ vhost.root | default('/var/www/' + vhost.server_name) }};

        access_log /var/log/nginx/{{ vhost.server_name }}-access.log;
        error_log  /var/log/nginx/{{ vhost.server_name }}-error.log;

        location / {
            try_files $uri $uri/ =404;
        }

{% if vhost.enable_php | default(false) %}
        location ~ \.php$ {
            fastcgi_pass unix:/var/run/php/php{{ vhost.php_version | default('8.1') }}-fpm.sock;
            fastcgi_index index.php;
            include fastcgi_params;
        }
{% endif %}

{% if vhost.enable_ssl | default(false) %}
        listen 443 ssl;
        ssl_certificate /etc/ssl/certs/{{ vhost.server_name }}.crt;
        ssl_certificate_key /etc/ssl/private/{{ vhost.server_name }}.key;
        ssl_protocols TLSv1.2 TLSv1.3;
{% endif %}

{% if vhost.locations is defined %}
{% for location in vhost.locations %}
        location {{ location.path }} {
            {% if location.proxy_pass is defined %}
            proxy_pass {{ location.proxy_pass }};
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            {% endif %}
            {% if location.alias is defined %}
            alias {{ location.alias }};
            {% endif %}
        }
{% endfor %}
{% endif %}
    }

{% endfor %}
}
