# Configuration de {{ app_name }}
# Généré par Ansible le {{ ansible_date_time.date }}
# NE PAS MODIFIER MANUELLEMENT

[général]
nom={{ app_name }}
version={{ app_version }}
environnement={{ app_environment | default('production') }}

[serveur]
hôte={{ server_host | default('0.0.0.0') }}
port={{ server_port | default(8080) }}
workers={{ server_workers | default(4) }}

[base_de_données]
hôte={{ db_host | default('localhost') }}
port={{ db_port | default(5432) }}
nom={{ db_name }}
{% if db_ssl | default(false) %}
ssl=activé
ssl_cert={{ db_ssl_cert }}
{% else %}
ssl=désactivé
{% endif %}

[journalisation]
niveau={{ log_level | default('INFO') }}
fichier={{ log_file | default('/var/log/' + app_name + '.log') }}
{% if log_handlers is defined %}
gestionnaires={{ log_handlers | join(',') }}
{% endif %}
